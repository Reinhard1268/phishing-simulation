# .env.example
#  Enterprise Phishing Simulation & Automated Defense
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── GoPhish ─────────────────────────────────────────────────────
GOPHISH_URL=http://localhost:3333
GOPHISH_API_KEY=your_api_key_here

# ── MailHog (local lab SMTP) ────────────────────────────────────
MAILHOG_URL=http://localhost:8025
MAILHOG_SMTP=localhost:1025

# ── Elasticsearch ───────────────────────────────────────────────
ELASTIC_URL=http://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=your_password_here

# ── Wazuh ───────────────────────────────────────────────────────
WAZUH_URL=http://localhost:55000
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=your_password_here

# ── TheHive ─────────────────────────────────────────────────────
THEHIVE_URL=http://localhost:9000
THEHIVE_API_KEY=your_api_key_here

# ── Slack Notifications ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/YOUR/WEBHOOK/URL

# ── VirusTotal ──────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_vt_key_here

# ── Lab Configuration ───────────────────────────────────────────
PHISHING_LAB_DOMAIN=phishing-lab.local
SOC_EMAIL=soc@company.local
LOG_LEVEL=INFO
